# Google Maps API Key (required for GPS Survey feature)
# Get your key from: https://console.cloud.google.com/apis/credentials
# 1. Create a new API key
# 2. Restrict it to Maps Embed API and Maps JavaScript API
# 3. Copy below
VITE_GOOGLE_MAPS_API_KEY=your_api_key_here

# MongoDB connection (optional - app works without it)
MONGODB_URI=mongodb://localhost:27017/propsafe

# Anthropic API key (optional - chat feature has fallback)
ANTHROPIC_API_KEY=your_key_here
